    <!-- Cookies Banner -->
    <div id="cookie-banner" class="fixed bottom-4 left-4 right-4 md:left-1/2 md:-translate-x-1/2 md:w-[720px] z-[100] bg-white text-gray-800 rounded-xl shadow-lg border border-gray-200 p-4 md:p-5 hidden">
        <div class="flex items-start gap-4">
            <div class="flex-1">
                <p class="text-sm md:text-base">I use cookies to enhance your browsing experience, serve personalized ads or content, and analyze my traffic. By clicking "Accept All", you consent to my use of cookies. Read my <a href="privacy-policy.html" class="text-blue-600 hover:text-blue-800 underline">Privacy Policy</a>.</p>
                <details class="mt-2">
                    <summary class="cursor-pointer text-sm text-gray-600">Cookie settings</summary>
                    <div class="mt-2 text-sm text-gray-700 space-y-1">
                        <label class="flex items-center gap-2"><input type="checkbox" checked disabled> Strictly necessary</label>
                        <label class="flex items-center gap-2"><input id="cookie-analytics" type="checkbox" checked> Analytics</label>
                        <label class="flex items-center gap-2"><input id="cookie-marketing" type="checkbox"> Marketing</label>
                    </div>
                </details>
            </div>
            <div class="flex flex-col md:flex-row gap-2 md:gap-3">
                <button id="cookie-accept" class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-blue-700">Accept All</button>
                <button id="cookie-decline" class="border border-gray-300 text-gray-700 px-4 py-2 rounded-lg text-sm hover:bg-gray-100">Decline</button>
            </div>
        </div>
    </div>

    <script>
        (function() {
            const STORAGE_KEY = 'mik_cookie_consent_v1';
            function getConsent() { try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || 'null'); } catch(e) { return null; } }
            function setConsent(value) { localStorage.setItem(STORAGE_KEY, JSON.stringify(value)); }
            function showBanner() { document.getElementById('cookie-banner').classList.remove('hidden'); }
            function hideBanner() { document.getElementById('cookie-banner').classList.add('hidden'); }
            function init() {
                const existing = getConsent();
                if (!existing) { showBanner(); }
                const accept = document.getElementById('cookie-accept');
                const decline = document.getElementById('cookie-decline');
                accept && accept.addEventListener('click', () => { setConsent({ all:true, analytics:true, marketing:true, ts:Date.now() }); hideBanner(); });
                decline && decline.addEventListener('click', () => {
                    const analytics = document.getElementById('cookie-analytics')?.checked || false;
                    const marketing = document.getElementById('cookie-marketing')?.checked || false;
                    setConsent({ all:false, analytics, marketing, ts:Date.now() }); hideBanner();
                });
            }
            document.readyState === 'loading' ? document.addEventListener('DOMContentLoaded', init) : init();
        })();
    </script>
</body>
</html>